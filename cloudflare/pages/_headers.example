/*
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src 'self' https://REPLACE-WITH-STAGING-WORKER.workers.dev; object-src 'none'; base-uri 'none'; frame-ancestors 'none'; form-action 'none';
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
